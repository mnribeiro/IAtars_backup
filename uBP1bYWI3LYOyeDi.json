"c9249832-ca82-47a6-97b6-23b10e9e1b58","name":"Wait5","type":"n8n-nodes-base.wait","typeVersion":1.1,"position":[-2112,2224],"webhookId":"d2608e95-2419-4f68-af29-8aa4483c7b30","disabled":true},{"parameters":{"operation":"get","key":"={{ $('Code3').item.json.sessionId }}","options":{}},"id":"7afc6771-2a4d-4643-b7a7-3ae591f883c0","name":"Get Memory ","type":"n8n-nodes-base.redis","typeVersion":1,"position":[-2272,2224],"credentials":{"redis":{"id":"eb93QKXEtpZuUane","name":"Redis account"}}},{"parameters":{"operation":"get","key":"={{ $('Code3').item.json.sessionId }}","options":{}},"id":"f26341fc-5276-4d12-9278-ab5687f73bea","name":"Get Memory 3","type":"n8n-nodes-base.redis","typeVersion":1,"position":[-1952,2224],"credentials":{"redis":{"id":"eb93QKXEtpZuUane","name":"Redis account"}}},{"parameters":{"jsCode":"/**\n * Recebe items contendo campos Redis1 e Redis2 como strings JSON de arrays de mensagens.\n * Analisa ambos, une apenas as mensagens diferentes (sem duplicatas) e retorna uma única string.\n */\nfunction mergeUniqueMessages(items) {\n  // Obtém as strings brutas\n  const raw1 = items[0].json.Redis1;\n  const raw2 = items[0].json.Redis2;\n\n  // Função para parsear com segurança\n  function safeParse(raw) {\n    if (!raw) return [];\n    try {\n      const parsed = JSON.parse(raw);\n      return Array.isArray(parsed) ? parsed : [parsed];\n    } catch {\n      return [raw];\n    }\n  }\n\n  // Parse das duas fontes\n  const arr1 = safeParse(raw1);\n  const arr2 = safeParse(raw2);\n\n  // Une e remove duplicatas mantendo ordem de ocorrência\n  const unique = [];\n  [...arr1, ...arr2].forEach(msg => {\n    if (!unique.includes(msg)) unique.push(msg);\n  });\n\n  // Junta numa única conversa\n  const conversation = unique.join(' ');\n\n  return [{ json: { conversation } }];\n}\n\n// No n8n Function Node, basta retornar:\nreturn mergeUniqueMessages(items);\n"},"id":"f07526ab-e230-41b6-8718-2ebfadadfa8e","name":"Mensagem Completa","type":"n8n-nodes-base.code","