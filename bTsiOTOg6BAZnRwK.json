\n  resumo[chave].contatos.add(telefone_cliente);\n}\n\n// Monta saída final\nconst saida = Object.values(resumo).map(r => ({\n  data_registro: dataRegistro,\n  loja: r.loja,\n  vendedor: r.vendedor,\n  total_contatos: r.contatos.size\n}));\n\nreturn saida.map(r => ({ json: r }));\n"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[-1104,-880],"id":"9a11dc94-36b0-4e55-8f6a-42c72b09f12d","name":"Code in JavaScript"},{"parameters":{"useCustomSchema":true,"schema":"TMC_Alberto","tableId":"registro_vendedores","fieldsUi":{"fieldValues":[{"fieldId":"data_registro","fieldValue":"={{ $json.data_registro.split('/').reverse().join('-') }}"},{"fieldId":"vendedor","fieldValue":"={{ $json.vendedor }}"},{"fieldId":"total_contatos","fieldValue":"={{ $json.total_contatos }}"},{"fieldId":"loja","fieldValue":"={{ $json.loja }}"}]}},"type":"n8n-nodes-base.supabase","typeVersion":1,"position":[-896,-880],"id":"61bb3887-f5e6-44f9-a9e3-b4291e689feb","name":"Create a row","credentials":{"supabaseApi":{"id":"PSMftmurua48DZ8o","name":"Supabase account"}}},{"parameters":{"jsCode":"// Junta os itens do input do n8n em um único array\nconst allItems = $input.all();\nconst rows = allItems.map(i => i.json.data ? i.json.data : i.json).flat();\n\n// Garante que há dados\nif (!Array.isArray(rows) || rows.length === 0) {\n  return [{\n    json: {\n      data: new Date().toLocaleDateString(\"pt-BR\", { timeZone: \"America/Sao_Paulo\" }),\n      resumo: {},\n      relatorio_texto: \"⚠️ Nenhum dado disponível para gerar o relatório.\"\n    }\n  }];\n}\n\n// Agrupamento por loja e vendedor usando total_contatos existente\nconst resumo = {};\nfor (const item of rows) {\n  const { loja, vendedor, total_contatos } = item;\n  if (!loja || !vendedor) continue;\n\n  if (!resumo[loja]) resumo[loja] = {};\n  resumo[loja][vendedor] = (resumo[loja][vendedor] || 0) + (Number(total_contatos) || 0);\n}\n\n// Geração do relatório formatado\nconst dataHoje = new Date().toLocaleDateString(\"pt-BR\", { timeZone: \"America/Sao_Paulo\" });\nlet relatorio = `📈 *Relatório Diário de Interações*\\n📅 Data: ${dataHoje}\\n\\n`;\n\nlet totalGeral = 0;\nfor (const loja of Object.keys(resumo)) {\n  relatorio += `🏬 *Loja ${loja}*\\n`;\n  const vendedores = Object.entries(resumo[loja]).sort((a, b) => b[1] - a[1]);\n\n  let totalLoja = 0;\n  for (const [vendedor, total] of vendedores) {\n    relatorio += `   • ${vendedor}: ${total} interações\\n`;\n    totalLoja += total;\n  }\n\n  relatorio += `   ↳ Total da loja: *${totalLoja}*\\n\\n`;\n  totalGeral += totalLoja;\n}\n\nrelatorio += `📊 *Total geral:* ${totalGeral} interações registradas.`;\n\n// Retorno final\nreturn [{\n  json: {\n    data: dataHoje,\n    resumo,\n    relatorio_texto: relatorio.trim()\n  }\n}];\n"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[-896,-1056],"id":"9d1f7f7b-0bff-4f2b-81d7-a865fa9638f1","name":"Code in JavaScript1"},{"parameters":{"operation":"deleteTable","schema":{"__rl":true,"value":"TMC_Alberto","mode":"list","cachedResultName":"TMC_Alberto"},"table":{"__rl":true,"value":"clientes","mode":"list","cachedResultName":"clientes"},"options":{}},"type":"n8n-nodes-base.postgres","typeVersion":2.6,"position":[-688,-880],"id":"c9509a88-6953-4b10-988c-e5d71b829b7e","name":"Delete table or rows","credentials":{"postgres":{"id":"M4iKJE2QWaXY4L2F","name":"supabasepostgres"}}},{"parameters":{},"type":"n8n-nodes-base.manualTrigger","typeVersion":1,"position":[-1744,-1104],"id":"a1d757f9-d920-4f23-a011-1ee098ff995c","name":"When clicking ‘Execute workflow’"},{"parameters":{"useCustomSchema":true,"schema":"TMC_Marcel","operation":"getAll","tableId":"disparos","returnAll":true},"type":"n8n-nodes-base.supabase","typeVersion":1,"position":[-1360,-1136],"id":"d834330a-2fde-4713-8f6a-bbe69767058d","name":"Get many rows1","credentials":{"supabaseApi":{"id":"PSMftmurua48DZ8o","name":"Supabase account"}}},{"parameters":{"jsCode":"// Pega todos os dados que chegaram ao Function Node\nconst dados = items.map(item => item.json);\n\n// Total de disparos recebidos\nconst totalDisparos = dados.length;\n\n// Agrupa clientes por telefone\nconst clientesAgrupados = dados.reduce((acc, item) => {\n  const tel = item.telefone_cliente;\n\n  if (!acc[tel]) {\n    acc[tel] = {\n      nome: item.nome_cliente,\n      telefone: tel,\n      registros: []\n    };\n  }\n\n  acc[tel].registros.push({\n    id: item.id,\n    etapa: item.etapa,\n    data_disparo: new Date(item.data_disparo),\n    numero_loja: item.numero_loja\n  });\n\n  return acc;\n}, {});\n\n// Processa clientes convertidos\nconst convertidos = Object.values(clientesAgrupados)\n  .filter(c => c.registros.length > 1)\n  .map(cliente => {\n    // Ordena registros pela data\n    const registrosOrdenados = cliente.registros.sort((a, b) => a.data_disparo - b.data_disparo);\n\n    // Detecta se existe um caso em que 24h vem DEPOIS de 7d ou 15d\n    let conversao = false;\n    for (let i = 0; i < registrosOrdenados.length; i++) {\n      const etapa = registrosOrdenados[i].etapa;\n      if (etapa === \"7d\" || etapa === \"15d\") {\n        const posteriores = registrosOrdenados.slice(i + 1);\n        if (posteriores.some(r => r.etapa === \"24h\")) {\n          conversao = true;\n          break;\n        }\n      }\n    }\n\n    return {\n      nome: cliente.nome,\n      telefone: cliente.telefone,\n      vezes: registrosOrdenados.length,\n      primeira_interacao: registrosOrdenados[0].data_disparo,\n      ultima_interacao: registrosOrdenados[registrosOrdenados.length - 1].data_disparo,\n      etapas: registrosOrdenados.map(r => r.etapa),\n      conversao_valida: conversao\n    };\n  })\n  .filter(c => c.conversao_valida); // mantém só os que tiveram conversão real\n\n// Totais\nconst totalConvertidos = convertidos.length;\nconst percentual = ((totalConvertidos / totalDisparos) * 100).toFixed(2);\n\n// Saída JSON\nconst resultadoJson = {\n  resumo: {\n    total_disparos: totalDisparos,\n    total_conversoes: totalConvertidos,\n    percen