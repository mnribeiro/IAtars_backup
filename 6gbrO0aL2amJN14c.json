peVersion":4.2,"position":[80,2816],"id":"6189c07f-7aa6-4938-b084-05628e2e02b5","name":"HTTP Request10","credentials":{"httpBasicAuth":{"id":"nwzPsMWccy17Skrp","name":"TMC"}}},{"parameters":{"numberInputs":5},"type":"n8n-nodes-base.merge","typeVersion":3.1,"position":[352,2544],"id":"e344655b-1fc1-4590-8f98-b836e2e6a85d","name":"Merge1"},{"parameters":{"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[-288,2624],"id":"99aedda5-f9e3-483d-b3d1-19cf7fc1d50d","name":"Edit Fields1"},{"parameters":{"useCustomSchema":true,"schema":"TMC_Alberto","tableId":"=preço_MC","fieldsUi":{"fieldValues":[{"fieldId":"codigo_produto","fieldValue":"={{ $json.codigoProduto }}"},{"fieldId":"preco","fieldValue":"={{$json.preco}}"}]}},"type":"n8n-nodes-base.supabase","typeVersion":1,"position":[736,2592],"id":"cfee9e8a-0312-4011-9e21-f5fce280bcfd","name":"Supabase3","credentials":{"supabaseApi":{"id":"PSMftmurua48DZ8o","name":"Supabase account"}}},{"parameters":{"jsCode":"const resultados = [];\n\nfor (const item of items) {\n  const codigoProduto = item.json.codigoProduto;\n  \n  // Busca a tabela com códigoTabela === '1'\n  const tabela1 = item.json.tabelasPrecos.find(t => t.codigoTabela === '1');\n\n  if (tabela1 && tabela1.preco !== null) {\n    resultados.push({\n      json: {\n        codigoProduto,\n        preco: tabela1.preco\n      }\n    });\n  }\n}\n\nreturn resultados;\n"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[544,2592],"id":"06ccaf67-9e44-465f-a81e-a9feb138d3d2","name":"Code"},{"parameters":{"rule":{"interval":[{}]}},"type":"n8n-nodes-base.scheduleTrigger","typeVersion":1.2,"position":[-464,2624],"id":"e7ecc4d0-17f3-4036-bc0e-9f73f219f876","name":"Schedule Trigger1"},{"parameters":{"content":"# GET_PRECO","height":1080,"width":1740,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-736,2144],"id":"2ad82b57-a023-4043-8bcf-e2dcd84646ba","name":"Sticky Note2"},{"parameters":{"content":"# GET_PRODUTO","height":1080,"width":1740,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-736,928],"id":"3357c25b-fd45-4036-b667-b96852c1174c","name":"Sticky Note5"},{"parameters":{"content":"# DELETAR TABELA ATUAL ","height":340,"width":600,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1104,2416],"id":"bade0a04-e088-4baa-9745-af58547c8e97","name":"Sticky Note3"},{"parameters":{"operation":"deleteTable","schema":{"__rl":true,"value":"TMC_Alberto","mode":"list","cachedResultName":"TMC_Alberto"},"table":{"__rl":true,"value":"preço_MC","mode":"list","cachedResultName":"preço_MC"},"options":{}},"type":"n8n-nodes-base.postgres","typeVersion":2.6,"position":[1376,2560],"id":"e1f4d6a5-3f83-42ce-a19c-716c332dd046","name":"Postgres1","credentials":{"postgres":{"id":"M4iKJE2QWaXY4L2F","name":"supabasepostgres"}}},{"parameters":{"jsCode":"// Filtro: só entra no processamento se tiver item válido e com campos certos\nconst itensValidos = (items || []).filter(item =>\n  item.json &&\n  typeof item.json.preco_curva   !== 'undefined' &&\n  typeof item.json.preco_erp     !== 'undefined' &&\n  typeof item.json.descricao     !== 'undefined' &&\n  typeof item.json.codigo_produto !== 'undefined'\n);\n\nif (!itensValidos.length) {\n  return [{\n    json: {\n      mensagem: \"🔎 Não houve alteração de preços entre as listas comparadas.\"\n    }\n  }];\n}\n\n// Processa os itens válidos\nconst processados = itensValidos.map(item => {\n  const antes      = Number(item.json.preco_curva);\n  const depois     = Number(item.json.preco_erp);\n  const diferenca  = +(depois - antes).toFixed(2);\n\n  return {\n    ...item.json,\n    antes,\n    depois,\n    diferenca\n  };\n});\n\n// Mantém apenas os itens onde houve mudança de preço\nconst alterados = processados\n  .filter(i => i.diferenca !== 0)\n  .sort((a, b) => Math.abs(b.diferenca) - Math.abs(a.diferenca));\n\nlet mensagem = `🔔 *Relatório de Alterações de Preços*\\n\\n`;\n\nif (!alterados.length) {\n  mensagem += `Nenhuma alteração de preço encontrada.\\n`;\n} else {\n  mensagem += `📋 *Alterações detectadas*\\n\\n`;\n  alterados.forEach(i => {\n    mensagem += `• ${i.descricao} (Cód: ${i.codigo_produto})\\n   De: R$ ${i.antes.toFixed(2)} → Para: R$ ${i.depois.toFixed(2)} | Diferença: R$ ${i.diferenca > 0 ? '+' : ''}${i.diferenca.toFixed(2)}\\n\\n`;\n  });\n}\n\nreturn [{ json: { mensagem } }];\n"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[2320,2608],"id":"aba343d2-0eae-4b9e-b678-38ea7bfcd0e9","name":"Code1"},{"parameters":{"content":"# VERIFICAR DIFERENÇAS E NOTIFICAR CLIENTE ","height":420,"width":980,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1776,2368],"id":"43e91069-8993-4720-bc29-e66997ac2fc4","name":"Sticky Note4"},{"parameters":{"operation":"executeQuery","query":"SELECT\n  dm.codigo_produto,\n  dm.descricao,\n  dm.preco AS preco_curva,        -- mantém nome esperado pelo JS\n  pmc.preco AS preco_erp,         -- idem\n  CASE\n    WHEN pmc.preco > dm.preco THEN 'AUMENTOU'\n    WHEN pmc.preco < dm.preco THEN 'DIMINUIU'\n    ELSE 'IGUAL'\n  END AS status\nFROM \"TMC_Alberto\".\"produtos_filtrados_curva_abc\" AS dm\nJOIN \"TMC_Alberto\".\"preço_MC\" AS pmc\n  ON pmc.codigo_produto = dm.codigo_produto\nWHERE pmc.preco IS DISTINCT FROM dm.preco\nORDER BY status, dm.codigo_produto;\n","options":{}},"type":"n8n-nodes-base.postgres","typeVersion":2.6,"position":[2096,2608],"id":"f5d67b8d-3692-405b-875f-8b92a0c1c976","name":"verifica diferença de preços","alwaysOutputData":true,"credentials":{"postgres":{"id":"M4iKJE2QWaXY4L2F","name":"supabasepostgres"}}},{"parameters":{"operation":"executeQuery","query":"UPDATE \"TMC_Alberto\".\"produtos_filtrados_curva_abc\" AS dm\nSET preco = pmc.preco\nFROM \"TMC_Alberto\".\"preço_MC\" AS pmc\nWHERE pmc.codigo_produto = dm.codigo_produto\n  AND dm.preco IS DISTINCT FROM pmc.preco;","options":{}},"type":"n8n-nodes-base.postgres","typeVersion":2.6,"position":[2320,2448],"id":"23c85f47-c5b4-40a4-a9af-327d7ac9f165","name":"Atualiza Planilha principal","credentials":{"postgres":{"id":"M4iKJE2QWaXY4L2F","name":"supabasepostgres"}}},{"parameters":{"rule":{"interval":[{"triggerAtHour":7}]}},"type":"n8n-nodes-base.scheduleTrigger","typeVersion":1.2,"position":[1872,2608],"id":"c8d33fd0-3c67-4556-ac19-ed0a365cda08","name":"Schedule Trigger2"},{"parameters":{"numberInputs":5},"type":"n8n-nodes-base.merge","typeVersion":3.1,"position":[304,336],"id":"652eae0c-77e2-4d2e-95b9-ffb8f56019f1","name":"Merge2"},{"parameters":{"url":"http://159.112.189.1:25046/produtoEstoque","authentication":"genericCredentialType","genericAuthType":"httpBasicAuth","sendQuery":true,"queryParameters":{"parameters":[{"name":"codigoEmpresa","value":"067"},{"name":"numeroPagina","value":"0"},{"name":"quantidadeRegistro","value":"5000"}]},"sendHeaders":true,"headerParameters":{"parameters":[{"name":"accept","value":"application/json"}]},"options":{}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[0,176],"id":"12c33fa9-958e-4e0a-b6db-f05a9f0799a3","name":"HTTP Request11"},{"parameters":{"url":"http://159.112.189.1:25046/produtoEstoque","authentication":"genericCredentialType","genericAuthType":"httpBasicAuth","sendQuery":true,"queryParameters":{"parameters":[{"name":"codigoEmpresa","value":"067"},{"name":"numeroPagina","value":"0"},{"name":"quantidadeRegistro","value":"5000"}]},"sendHeaders":true,"headerParameters":{"parameters":[{"name":"accept","value":"application/json"}]},"options":{}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[0,368],"id":"b0332c9a-91f7-4789-b5e1-8e8f3f961d1c","name":"HTTP Request12"},{"parameters":{"url":"http://159.112.189.1:25046/produtoEstoque","authentication":"genericCredentialType","genericAuthType":"httpBasicAuth","sendQuery":true,"queryParameters":{"parameters":[{"name":"codigoEmpresa","value":"067"},{"name":"numeroPagina","value":"0"},{"name":"quantidadeRegistro","value":"5000"}]},"sendHeaders":true,"headerParameters":{"paramet