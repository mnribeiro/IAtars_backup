{"updatedAt":"2026-02-17T17:57:06.328Z","createdAt":"2026-02-17T16:32:05.823Z","id":"64N3JDv2GUlTNLHt","name":"DUMP_SUPABASE_MULTITENANT","active":false,"isArchived":false,"nodes":[{"parameters":{"rule":{"interval":[{"triggerAtHour":7},{"triggerAtHour":13},{"triggerAtHour":19}]}},"id":"sched-01","name":"Schedule 3x dia","type":"n8n-nodes-base.scheduleTrigger","typeVersion":1.2,"position":[112,-128]},{"parameters":{"operation":"executeQuery","query":"SELECT c.empresa_id, c.nome_cliente, c.api_url, c.api_tintometrico_url, c.slug,\n  l.codigo AS codigo_loja, l.nome AS nome_loja\nFROM \"Controle_TMC\".configuracoes_cliente c\nJOIN \"Controle_TMC\".lojas l ON l.empresa_id = c.empresa_id\nWHERE c.ativo = true\nORDER BY c.nome_cliente, l.codigo","options":{}},"id":"pg-busca","name":"Busca Clientes Ativos","type":"n8n-nodes-base.postgres","typeVersion":2.5,"position":[224,0],"credentials":{"postgres":{"id":"M4iKJE2QWaXY4L2F","name":"supabasepostgres"}}},{"parameters":{"jsCode":"const empresas = {};\nfor (const item of items) {\n  const eid = item.json.empresa_id;\n  if (!empresas[eid]) {\n    empresas[eid] = {\n      empresa_id: eid,\n      nome_cliente: item.json.nome_cliente,\n      api_url: item.json.api_url,\n      api_tintometrico_url: item.json.api_tintometrico_url,\n      slug: item.json.slug,\n      lojas: []\n    };\n  }\n  empresas[eid].lojas.push({\n    codigo: item.json.codigo_loja,\n    nome: item.json.nome_loja\n  });\n}\nreturn Object.values(empresas).map(e => ({ json: e }));"},"id":"code-agrupa","name":"Agrupa por Empresa","type":"n8n-nodes-base.code","typeVersion":2,"position":[448,0]},{"parameters":{"options":{"reset":false}},"id":"loop-emp","name":"Loop Empresas","type":"n8n-nodes-base.splitInBatches","typeVersion":3,"position":[672,0]},{"parameters":{"operation":"executeQuery","query":"=DELETE FROM \"Controle_TMC\".precos_erp WHERE empresa_id = '{{ $json.empresa_id }}'","options":{}},"id":"pg-delete","name":"Limpa Precos Empresa","type":"n8n-nodes-base.p