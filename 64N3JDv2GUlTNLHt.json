oduto: dados.codigoProduto,\n        preco: tabela1.preco\n      }\n    });\n  }\n}\n\nif (resultados.length === 0) {\n  return [{ json: { _skip: true, count: 0 } }];\n}\n\n// Batch em grupos de 500\nconst BATCH = 500;\nconst batches = [];\nfor (let i = 0; i < resultados.length; i += BATCH) {\n  const chunk = resultados.slice(i, i + BATCH);\n  const values = chunk.map(r =>\n    \"('\" + r.json.empresa_id + \"', \" + r.json.codigo_produto + \", \" + r.json.preco + \")\"\n  ).join(',\n');\n\n  batches.push({\n    json: {\n      _skip: false,\n      count: chunk.length,\n      insert_sql: 'INSERT INTO \"Controle_TMC\".precos_erp (empresa_id, codigo_produto, preco) VALUES ' + values\n    }\n  });\n}\n\nreturn batches;"},"id":"code-processa","name":"Processa Precos","type":"n8n-nodes-base.code","typeVersion":2,"position":[1792,0]},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":1},"conditions":[{"id":"f1","leftValue":"={{ $json._skip }}","rightValue":true,"operator":{"type":"boolean","operation":"notEquals"}}],"combinator":"and"},"options":{}},"id":"filter-skip","name":"Filtra Vazios","type":"n8n-nodes-base.filter","typeVersion":2,"position":[1984,0]},{"parameters":{"operation":"executeQuery","query":"={{ $json.insert_sql }}","options":{}},"id":"pg-insert","name":"Insere Precos","type":"n8n-nodes-base.postgres","typeVersion":2.5,"position":[2208,0],"credentials":{"postgres":{"id":"M4iKJE2QWaXY4L2F","name":"supabasepostgres"}}},{"parameters":{"operation":"executeQuery","query":"=UPDATE \"Controle_TMC\".produtos_curva_abc p\nSET preco = e.preco, updated_at = now()\nFROM \"Controle_TMC\".precos_erp e\nWHERE e.codigo_produto = p.codigo_produto\n  AND e.empresa_id = p.empresa_id\n  AND p.empresa_id = '{{ $('Loop Empresas').first().json.empresa_id }}'\n  AND p.preco IS DISTINCT FROM e.preco","options":{}},"id":"pg-update","name":"Atualiza Curva ABC","type":"n8n-nodes-base.postgres","typeVersion":2.5,"position":[24