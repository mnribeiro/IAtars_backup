  }\n}\n\nif (values.length === 0) {\n  return [{ json: { _skip: true, count: 0 } }];\n}\n\nconst batches = [];\nconst BATCH = 500;\nfor (let i = 0; i < values.length; i += BATCH) {\n  const chunk = values.slice(i, i + BATCH);\n  batches.push({\n    json: {\n      _skip: false,\n      count: chunk.length,\n      insert_sql: 'INSERT INTO \"Controle_TMC\".precos_erp (empresa_id, codigo_produto, preco) VALUES ' + chunk.join(',')\n    }\n  });\n}\nreturn batches;"},"id":"code-processa","name":"Processa Precos","type":"n8n-nodes-base.code","typeVersion":1,"position":[1808,16]},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":1},"conditions":[{"id":"f1","leftValue":"={{ $json._skip }}","rightValue":true,"operator":{"type":"boolean","operation":"notEquals"}}],"combinator":"and"},"options":{}},"id":"filter-skip","name":"Filtra Vazios","type":"n8n-nodes-base.filter","typeVersion":2,"position":[2016,16]},{"parameters":{"operation":"executeQuery","query":"{{ $json.insert_sql }}","options":{}},"id":"pg-insert","name":"Insere Precos","type":"n8n-nodes-base.postgres","typeVersion":2.5,"position":[2240,16],"credentials":{"postgres":{"id":"M4iKJE2QWaXY4L2F","name":"supabasepostgres"}}},{"parameters":{"operation":"executeQuery","query":"UPDATE \"Controle_TMC\".produtos_curva_abc p\nSET preco = e.preco, updated_at = now()\nFROM \"Controle_TMC\".precos_erp e\nWHERE e.codigo_produto = p.codigo_produto\n  AND e.empresa_id = p.empresa_id\n  AND p.empresa_id = '{{ $('Loop Empresas').first().json.empresa_id }}'\n  AND p.preco IS DISTINCT FROM e.preco","options":{}},"id":"pg-update","name":"Atualiza Curva ABC","type":"n8n-nodes-base.postgres","typeVersion":2.5,"position":[2448,16],"credentials":{"postgres":{"id":"M4iKJE2QWaXY4L2F","name":"supabasepostgres"}}},{"parameters":{},"id":"noop-back","name":"Proximo Cliente","type":"n8n-nodes-base.noOp","typeVersion":1,"position":[2656,16]},{"parameters":{},"type":"n8n-nodes-base.manual