propertyName }}","type":"string"},{"id":"946d1420-e379-46e3-8fcd-3816340fbabb","name":"Redis1","value":"={{ $json.propertyName }}","type":"string"}]},"options":{}},"id":"2b92ee91-78da-4484-a696-c7b78ddc7680","name":"Edit Fields12","type":"n8n-nodes-base.set","typeVersion":3.4,"position":[-2336,208]},{"parameters":{"jsCode":"/**\n * Recebe items contendo campos Redis1 e Redis2 como strings JSON de arrays de mensagens.\n * Analisa ambos, une apenas as mensagens diferentes (sem duplicatas) e retorna uma única string.\n */\nfunction mergeUniqueMessages(items) {\n  // Obtém as strings brutas\n  const raw1 = items[0].json.Redis1;\n  const raw2 = items[0].json.Redis2;\n\n  // Função para parsear com segurança\n  function safeParse(raw) {\n    if (!raw) return [];\n    try {\n      const parsed = JSON.parse(raw);\n      return Array.isArray(parsed) ? parsed : [parsed];\n    } catch {\n      return [raw];\n    }\n  }\n\n  // Parse das duas fontes\n  const arr1 = safeParse(raw1);\n  const arr2 = safeParse(raw2);\n\n  // Une e remove duplicatas mantendo ordem de ocorrência\n  const unique = [];\n  [...arr1, ...arr2].forEach(msg => {\n    if (!unique.includes(msg)) unique.push(msg);\n  });\n\n  // Junta numa única conversa\n  const conversation = unique.join(' ');\n\n  return [{ json: { conversation } }];\n}\n\n// No n8n Function Node, basta retornar:\nreturn mergeUniqueMessages(items);\n"},"id":"eb052e5f-120c-48f0-a64e-bce995509853","name":"Mensagem Completa1","type":"n8n-nodes-base.code","typeVersion":2,"position":[-1888,192]},{"parameters":{"operation":"push","list":"={{ $('Edit Fields2').item.json.sessionID }}","messageData":"={{ $('dados_para_atendimento_humano1').item.json.mensagem }}","tail":true},"id":"933a06fb-7ac5-476c-873b-d41239eb3e7a","name":"Text Memory","type":"n8n-nodes-base.redis","typeVersion":1,"position":[-3216,80],"credentials":{"redis":{"id":"eb93QKXEtpZuUane","name":"Redis account"}}},{"parameters":{"operation":"binaryToPropery","binaryPropertyName":"=dat