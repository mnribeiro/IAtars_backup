e-block;\n        }\n\n        /* Conteúdo Principal */\n        .content {\n            padding: 30px;\n        }\n\n        h1 {\n            color: #FFFFFF;\n            /* White for Dark Mode */\n            font-size: 24px;\n            margin-bottom: 20px;\n            text-align: center;\n            line-height: 1.3;\n        }\n\n        p {\n            font-size: 16px;\n            margin-bottom: 20px;\n            color: #CCCCCC;\n            /* Light Gray for Dark Mode */\n        }\n\n        b,\n        strong {\n            color: #FFFFFF;\n            /* Negrito sempre branco para destaque */\n        }\n\n        /* Destaques / Bullets */\n        .features {\n            background-color: #2D2D2D;\n            /* Dark Box */\n            padding: 20px;\n            border-radius: 8px;\n            margin: 25px 0;\n            border-left: 6px solid #FFC20E;\n        }\n\n        .features ul {\n            list-style: none;\n            padding: 0;\n            margin: 0;\n        }\n\n        .features li {\n            margin-bottom: 12px;\n            /* padding-left removed for inline emoji */\n            font-weight: 600;\n            color: #E0E0E0;\n            /* Forçar cor clara na lista */\n            list-style-type: none;\n            /* Ensure no default bullets */\n        }\n\n        /* ::before rule removed for better mobile compatibility */\n\n        /* Botão CTA */\n        .cta-container {\n            text-align: center;\n            margin: 35px 0;\n        }\n\n        .cta-button {\n            background-color: #008a00;\n            color: #ffffff !important;\n            padding: 14px 30px;\n            /* Reduced padding */\n            text-decoration: none;\n            font-size: 16px;\n            /* Slightly smaller font */\n            font-weight: bold;\n            border-radius: 5px;\n            display: inline-block;\n            transition: background-color 0.3s;\n            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.2);\n        }\n\n        .cta-button:hover {\n            background-color: #006600;\n        }\n\n        /* Footer */\n        .footer {\n            background-color: #333333;\n            color: #ffffff;\n            text-align: center;\n            padding: 10px;\n            font-size: 12px;\n        }\n\n        .footer a {\n            color: #aaaaaa;\n            text-decoration: none;\n        }\n\n        /* Responsividade */\n        @media only screen and (max-width: 600px) {\n            .email-container {\n                width: 100% !important;\n            }\n\n            .content {\n                padding: 15px;\n                /* Reduzir padding em telas pequenas */\n            }\n\n            h1 {\n                font-size: 22px;\n                /* Ajuste fino */\n            }\n\n            .cta-button {\n                width: 100%;\n                box-sizing: border-box;\n                display: block;\n                /* Garantir bloco no mobile */\n                padding: 12px 0;\n                /* Menor padding vertical */\n                text-align: center;\n            }\n        }\n    </style>\n</head>\n\n<body>\n\n    <div class=\"email-container\">\n        <!-- Header Image -->\n        <div class=\"header\">\n            <img src=\"https://iili.io/fSaCsXs.png\" alt=\"ProQuantum Ciacollor\">\n        </div>\n\n        <div class=\"content\">\n            <!-- Título: Foco em Parceria e Solidez -->\n            <h1>Pare de sofrer com atrasos e margem curta. Conheça a <span style=\"color: #F37021;\">Ciacollor.</span>\n            </h1>\n            <p>Olá, {{ $json.Nome }} </p>\n\n            <p>\n                A <b>Pró Quantum</b> é a representante de vendas dos produtos <b>Ciacollor</b> para São Paulo e região.\n            </p>\n\n            <p>\n                Trabalhamos com <b>preço direto da fábrica</b>. Isso significa que você leva a qualidade técnica que\n                seus pintores exigem (Certificação PSQ/ABRAFATI) com <b>margens de lucro superiores</b> para o seu\n                negócio.\n            </p>\n\n            <div class=\"features\">\n                <p style=\"margin-top: 0; font-weight: bold; color: #F37021; margin-bottom: 15px;\">O que estamos\n                    construindo com nossos parceiros:</p>\n                <ul>\n                    <li>✅ <b>Preço Direto da Fábrica:</b> Margens muito acima da média do mercado.</li>\n                    <li>✅ Qualidade Técnica de Nível Premium (PSQ/ABRAFATI).</li>\n                    <li>✅ Treinamento especializado para os pintores da sua região.</li>\n                    <li>✅ <b></b>Logística Ágil:</b> Novo CD em São Paulo para entrega expressa em toda a região.</li>\n                </ul>\n            </div>\n\n            <p>\n                Temos uma condição exclusiva para novos parceiros essa semana e nossa equipe técnica está pronta\n                para\n                tirar todas as suas dúvidas agora mesmo.\n            </p>\n\n            <!-- Botão Focado na Ação / Conversa -->\n            <div class=\"cta-container\">\n                <a href=\"https://wa.me/5511939373127?text=Ol%C3%A1%2C%20recebi%20o%20email%20da%20Ciacollor%20e%20gostaria%20de%20saber%20mais%20sobre%20a%20parceria\"\n                    class=\"cta-button\">\n                    💬 FALAR COM CONSULTOR AGORA\n                </a>\n            </div>\n\n            <p style=\"text-align: center; font-size: 14px; color: #777;\">\n                Clique no botão acima para iniciar um atendimento instantâneo pelo WhatsApp.\n            </p>\n        </div>\n\n        <div class=\"footer\">\n            <p>ProQuantum • Representante de vendas dos produtos Ciacollor</p>\n\n            <p>\n                <a href=\"#\">Descadastrar</a>\n            </p>\n        </div>\n    </div>\n\n</body>\n\n</html>"},"type":"n8n-nodes-base.html","typeVersion":1.2,"position":[688,0],"id":"c720162e-20fb-4cfa-9719-fc282225182a","name":"