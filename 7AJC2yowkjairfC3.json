:"n8n-nodes-base.set","typeVersion":3.4,"position":[-288,2576],"id":"819fd257-50ff-42bd-8346-40c111ec2f62","name":"Edit Fields1"},{"parameters":{"jsCode":"const resultados = [];\n\nfor (const item of items) {\n  const codigoProduto = item.json.codigoProduto;\n  \n  // Busca a tabela com códigoTabela === '1'\n  const tabela1 = item.json.tabelasPrecos.find(t => t.codigoTabela === '1');\n\n  if (tabela1 && tabela1.preco !== null) {\n    resultados.push({\n      json: {\n        codigoProduto,\n        preco: tabela1.preco\n      }\n    });\n  }\n}\n\nreturn resultados;\n"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[544,2544],"id":"ba3b7526-0632-4ad4-9640-14da9d6d4110","name":"Code"},{"parameters":{"rule":{"interval":[{}]}},"type":"n8n-nodes-base.scheduleTrigger","typeVersion":1.2,"position":[-496,2576],"id":"3677fff3-cf81-4122-8ef0-567b31c72f93","name":"Schedule Trigger1"},{"parameters":{"content":"# GET_PRECO","height":1080,"width":1740,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-736,2096],"id":"c230131f-731f-4e10-8825-652589f23854","name":"Sticky Note2"},{"parameters":{"content":"# GET_PRODUTO","height":1080,"width":1740,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[-736,928],"id":"dd478660-f53e-4a1a-82a1-79255fe426d6","name":"Sticky Note5"},{"parameters":{"content":"# DELETAR TABELA ATUAL ","height":340,"width":600,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1104,2416],"id":"5be3b27f-b188-4a23-a8c9-e77a284fa226","name":"Sticky Note3"},{"parameters":{"jsCode":"// Filtro: só entra no processamento se tiver item válido e com campos certos\nconst itensValidos = (items || []).filter(item =>\n  item.json &&\n  typeof item.json.preco_curva   !== 'undefined' &&\n  typeof item.json.preco_erp     !== 'undefined' &&\n  typeof item.json.descricao     !== 'undefined' &&\n  typeof item.json.codigo_produto !== 'undefined'\n);\n\nif (!itensValidos.length) {\n  return [{\n    json: {\n      mensagem: \"🔎 Não houve alteração de preços entre as listas comparadas.\"\n    }\n  }];\n}\n\n// Processa os itens válidos\nconst processados = itensValidos.map(item => {\n  const antes      = Number(item.json.preco_curva);\n  const depois     = Number(item.json.preco_erp);\n  const diferenca  = +(depois - antes).toFixed(2);\n\n  return {\n    ...item.json,\n    antes,\n    depois,\n    diferenca\n  };\n});\n\n// Mantém apenas os itens onde houve mudança de preço\nconst alterados = processados\n  .filter(i => i.diferenca !== 0)\n  .sort((a, b) => Math.abs(b.diferenca) - Math.abs(a.diferenca));\n\nlet mensagem = `🔔 *Relatório de Alterações de Preços*\\n\\n`;\n\nif (!alterados.length) {\n  mensagem += `Nenhuma alteração de preço encontrada.\\n`;\n} else {\n  mensagem += `📋 *Alterações detectadas*\\n\\n`;\n  alterados.forEach(i => {\n    mensagem += `• ${i.descricao} (Cód: ${i.codigo_produto})\\n   De: R$ ${i.antes.toFixed(2)} → Para: R$ ${i.depois.toFixed(2)} | Diferença: R$ ${i.diferenca > 0 ? '+' : ''}${i.diferenca.toFixed(2)}\\n\\n`;\n  });\n}\n\nreturn [{ json: { mensagem } }];\n"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[2320,2608],"id":"28c93ece-d241-4b19-a47e-b7760d351f47","name":"Code1"},{"parameters":{"content":"# VERIFICAR DIFERENÇAS E NOTIFICAR CLIENTE ","height":420,"width":980,"color":5},"type":"n8n-nodes-base.stickyNote","typeVersion":1,"position":[1776,2368],"id":"e179a47c-da05-462e-bd57-31c16df316de","name":"Sticky Note4"},{"parameters":{"operation":"executeQuery","query":"SELECT\n  dm.codigo_produto,\n  dm.descricao,\n  dm.preco AS preco_curva,        -- mantém nome esperado pelo JS\n  pmc.preco AS preco_erp,         -- idem\n  CASE\n    WHEN pmc.preco > dm.preco THEN 'AUMENTOU'\n    WHEN pmc.preco < dm.preco THEN 'DIMINUIU'\n    ELSE 'IGUAL'\n  END AS status\nFROM \"TMC_Marcel\".\"Curva_abc_marcel\" AS dm\nJOIN \"TMC_Marcel\".\"preço_MC_Marcel\" AS pmc\n  ON pmc.codigo_produto = dm.codigo_produto\nWHERE pmc.preco IS DISTINCT FROM dm.preco\nORDER BY status, dm.codigo_produto;\n","options":{}},"type":"n8n-nodes-base.postgres","typeVersion":2.6,"position":[2096,2608],"id":"554b774b-697e-4c8a-9222-b20e15ee008d","name":"verifica diferença de preços","alwaysOutputData":true},{"parameters":{"operation":"executeQuery","query":"UPDATE \"TMC_Marcel\".\"Curva_abc_marcel\" AS dm\nSET preco = pmc.preco\nFROM \"TMC_Marcel\".\"preço_MC_Marcel\" AS pmc\nWHERE pmc.codigo_produto = dm.codigo_produto\n  AND dm.preco IS DISTINCT FROM pmc.preco;\n","options":{}},"type":"n8n-nodes-base.postgres","typeVersion":2.6,"position":[2320,2432],"id":"417fb77e-6c47-4722-ad37-ef52f3185478","name":"Atualiza Planilha principal"},{"parameters":{"rule":{"interval":[{"triggerAtHour":7}]}},"type":"n8n-nodes-base.scheduleTrigger","typeVersion":1.2,"position":[1872,2608],"id":"e23d9b9f-c840-42dc-a28a-cc189d09eb6d","name":"Schedule Trigger2"},{"parameters":{"numberInputs":5},"type":"n8n-nodes-base.merge","typeVersion":3.1,"position":[304,336],"id":"4fb6e3c3-ab2f-4aea-a853-83a41203f455","name":"Merge2"},{"parameters":{"url":"http://159.112.189.1:25046/produtoEstoque","authentication":"genericCredentialType","genericAuthType":"httpBasicAuth","sendQuery":true,"queryParameters":{"parameters":[{"name":"codigoEmpresa","value":"067"},{"name":"numeroPagina","value":"0"},{"name":"quantidadeRegistro","value":"5000"}]},"sendHeaders":true,"headerParameters":{"parameters":[{"name":"accept","value":"application/json"}]},"options":{}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[0,176],"id":"726b5091-b8f1-4ae8-9d1f-71b1000e978c","name":"HTTP Request11"},{"parameters":{"url":"http://159.112.189.1:25046/produtoEstoque","authentication":"genericCredentialType","genericAuthType":"httpBasicAuth","sendQuery":true,"queryParameters":{"parameters":[{"name":"codigoEmpresa","value":"067"},{"name":"numeroPagina","value":"0"},{"name":"quantidadeRegistro","value":"5000"}]},"sendHeaders":true,"headerParameters":{"parameters":[{"name":"