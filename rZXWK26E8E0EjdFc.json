{"updatedAt":"2025-11-19T17:26:09.940Z","createdAt":"2025-11-12T22:57:35.284Z","id":"rZXWK26E8E0EjdFc","name":"Disparo email","active":false,"isArchived":false,"nodes":[{"parameters":{},"type":"n8n-nodes-base.manualTrigger","typeVersion":1,"position":[-176,0],"id":"1f11f11e-1563-42d3-b4dc-b9fd041940e0","name":"When clicking ‘Execute workflow’"},{"parameters":{"assignments":{"assignments":[{"id":"0c004c63-50af-461e-8458-f89622a031e7","name":"Nome","value":"={{ $json.NOME }}","type":"string"},{"id":"19d945f8-7c47-412a-badb-0c7e4cb01456","name":"telefone","value":"={{ $json.telefone }}","type":"string"},{"id":"6d268d25-d728-42ce-8a13-3e7719f36182","name":"email_destino","value":"={{ $json.EMAIL }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[464,0],"id":"e54b3df6-66ee-4b34-bac6-4fd52e4abfd1","name":"Edit Fields"},{"parameters":{"html":"<!DOCTYPE html>\n<html lang=\"pt-BR\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Black Friday Brasil Solos</title>\n    <style>\n        body {\n            margin: 0;\n            padding: 0;\n            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;\n            background-color: #f4f4f4;\n        }\n        .email-container {\n            max-width: 600px;\n            margin: 0 auto;\n            background-color: #ffffff;\n        }\n        /* AJUSTE: Imagem voltou para 600px */\n        .header-image {\n            width: 100%;\n            max-width: 600px; /* Voltou para 600px */\n            height: auto;\n            display: block;\n            margin: 0 auto; /* Centraliza a imagem */\n        }\n        .content {\n            padding: 40px 30px;\n            color: #333333;\n            line-height: 1.8;\n        }\n        .content h1 {\n            color: #1a1a1a;\n            font-size: 24px;\n            margin-bottom: 20px;\n            font-weight: 700;\n            text-transform: uppercase;\n            letter-spacing: -0.5px;\n        }\n        .content p {\n            font-size: 16px;\n            margin-bottom: 20px;\n            color: #555555;\n        }\n        /* Marca Brasil Solos em Azul */\n        .highlight {\n            color: #004080; \n            font-weight: 700;\n        }\n        .condicoes-box {\n            background-color: #222222; \n            color: #ffffff;\n            padding: 30px;\n            border-radius: 8px;\n            margin: 30px 0;\n            border-left: 6px solid #f0ad4e;\n        }\n        .condicoes-box h2 {\n            font-size: 18px;\n            color: #f0ad4e;\n            margin-bottom: 20px;\n            margin-top: 0;\n            text-transform: uppercase;\n        }\n        .condicoes-box ul {\n            list-style: none;\n            padding: 0;\n            margin: 0;\n        }\n        .condicoes-box li {\n            margin-bottom: 20px;\n            padding-left: 0;\n            font-size: 16px;\n            border-bottom: 1px solid #444;\n            padding-bottom: 10px;\n        }\n        .condicoes-box li:last-child {\n            margin-bottom: 0;\n            border-bottom: none;\n            padding-bottom: 0;\n        }\n        .condicoes-box strong {\n            color: #ffffff;\n            font-size: 18px;\n            display: block;\n            margin-bottom: 5px;\n        }\n        .condicoes-box span {\n            color: #cccccc;\n        }\n        /* Validade em Vermelho para Urgência */\n        .validade-alert {\n            text-align: center;\n            font-weight: bold;\n            color: #d9534f; /* Vermelho */\n            background-color: #fff3f3; /* Fundo avermelhado claro */\n            padding: 15px;\n            border-radius: 4px;\n            margin: 25px 0;\n            border: 1px dashed #d9534f; /* Borda vermelha */\n            font-size: 18px;\n        }\n        .cta-button {\n            display: inline-block;\n            padding: 18px 45px;\n            background-color: #004080; /* Botão Azul Escuro */\n            color: #ffffff !important;\n            text-decoration: none;\n            border-radius: 6px;\n            font-size: 18px;\n            font-weight: 700;\n            margin: 10px 0;\n            transition: background-color 0.3s;\n            box-shadow: 0 4px 6px rgba(0,0,0,0.1);\n        }\n        .cta-button:hover {\n            background-color: #003366;\n            transform: translateY(-2px);\n        }\n        .cta-center {\n            text-align: center;\n            margin-top: 30px;\n        }\n        .footer {\n            background-color: #f8f9fa;\n            color: #333333;\n            padding: 30px;\n            text-align: center;\n            font-size: 14px;\n            border-top: 1px solid #eeeeee;\n        }\n        .footer p {\n            margin: 5px 0;\n            color: #555555;\n        }\n        .tagline {\n            font-style: italic;\n            color: #004080;\n            font-size: 15px;\n            margin-top: 10px;\n        }\n        @media only screen and (max-width: 600px) {\n            .content {\n                padding: 30px 20px;\n            }\n            .content h1 {\n                font-size: 22px;\n            }\n            .cta-button {\n                width: 100%; \n                box-sizing: border-box;\n                text-align: center;\n            }\n        }\n    </style>\n</head>\n<body>\n    <div class=\"email-container\">\n        <img src=\"https://iili.io/fdsNS1a.png\" alt=\"Black Friday Brasil Solos\" class=\"header-image\">\n        \n        <div class=\"content\">\n            <h1>É hora de tirar o seu projeto do papel com a <span class=\"highlight\">Brasil Solos</span>.</h1>\n            \n            <p>\n                Sabemos que o final do ano é decisivo para a engenharia. Orçamentos precisam ser aprovados e obras precisam avançar. \n                Por isso, decidimos antecipar nossa <strong>Black Friday</strong> com uma condição comercial agressiva e inédita.\n            </p>\n            \n            <p>\n                Não importa o tamanho do seu desafio, agora temos a flexibilidade financeira ideal para atendê-lo com a excelência técnica de sempre.\n            </p>\n            \n            <div class=\"condicoes-box\">\n                <h2>🚀 Condições Exclusivas Liberadas:</h2>\n                <ul>\n                    <li>\n                        <strong>Orçamentos acima de R$ 50.000,00</strong>\n                        <span>Parcele em até 5x no boleto (Sem Juros)</span>\n                    </li>\n                    <li>\n                        <strong>Orçamentos acima de R$ 120.000,00</strong>\n                        <span>Parcele em até 10x no boleto (Sem Juros)</span>\n                    </li>\n                </ul>\n            </div>\n\n            <p>\n                Essa é a oportunidade para fechar seus contratos de sondagem, ensaios e controle tecnológico com o melhor custo-benefício do mercado.\n            </p>\n\n            <div class=\"validade-alert\">\n                ⚠️ ATENÇÃO: VÁLIDO ATÉ 25/11/2025\n            </div>\n            \n            <p style=\"text-align: center; margin-bottom: 0;\">\n                Não deixe para a última hora. Nossa agenda para o fim do ano já está sendo preenchida.\n            </p>\n            \n            <div class=\"cta-center\">\n                <a href=\"https://wa.me/5531988633298?text=Ol%C3%A1%2C%20recebi%20o%20email%20da%20Black%20Friday%20e%20quero%20aproveitar%20as%20condi%C3%A7%C3%B5es%20de%20parcelamento%21\" class=\"cta-button\">\n                    QUERO APROVEITAR AGORA\n                </a>\n            </div>\n        </div>\n        \n        <div class=\"footer\">\n            <p style=\"font-size: 16px; font-weight: bold;\">BRASIL SOLOS</p>\n            <p class=\"tagline\">Segurança que vem da base.</p>\n            \n            <p style=\"font-size: 11px; color: #999; margin-top: 20px;\">\n                Caso não queira mais receber nossos comunicados, \n                <a href=\"mailto:comercial@brasilsolos.com.br?subject=Descadastrar\" style=\"color: #004080; text-decoration: none;\">\n                    descadastre-se aqui.\n                </a>\n            </p>\n        </div>\n    </div>\n</body>\n</html>"},"type":"n8n-nodes-base.html","typeVersion":1.2,"position":[688,0],"id":"5b9d7fe5-ba54-4dfe-a709-425694520dc2","name":"HTML"},{"parameters":{"sendTo":"={{ $('Edit Fields').item.json.email_destino }}","subject":"Seu Laboratório em Até 10x SEM Juros - BLACK BRASIL SOLOS","message":"={{ $json.html }}","options":{}},"type":"n8n-nodes-base.gmail","typeVersion":2.1,"position":[1120,16],"id":"0479ad08-1465-4278-acc3-b690927b322c","name":"Send a message","webhookId":"841cf6c9-831d-4798-a23e-d29a81b8dc83","credentials":{"gmailOAuth2":{"id":"rJOvSJUAFmiVisS7","name":"Gmail Bstech"}}},{"parameters":{"options":{}},"type":"n8n-nodes-base.splitInBatches","typeVersion":3,"position":[896,0],"id":"88eb26ba-728f-4d97-9a8f-9f97d2f231ec","name":"Loop Over Items"},{"parameters":{},"type":"n8n-nodes-base.wait","typeVersion":1.1,"position":[1488,16],"id":"60b23c26-b586-4116-a0db-7d2d302b3c96","name":"Wait","webhookId":"b001ac99-f4c9-4a14-86a8-d5d241e26873"},{"parameters":{"documentId":{"__rl":true,"value":"1ZBVJpwIZRN0_O-pSq6qfuKNqOC05dlPjHpePUTI7AGQ","mode":"list","cachedResultName":"bstech disparos","cachedResultUrl":"https://docs.google.com/spreadsheets/d/1ZBVJpwIZRN0_O-pSq6qfuKNqOC05dlPjHpePUTI7AGQ/edit?usp=drivesdk"},"sheetName":{"__rl":true,"value":"gid=0","mode":"list","cachedResultName":"Página1","cachedResultUrl":"https://docs.google.com/spreadsheets/d/1ZBVJpwIZRN0_O-pSq6qfuKNqOC05dlPjHpePUTI7AGQ/edit#gid=0"},"filtersUI":{"values":[{"lookupColumn":"Disparos"}]},"options":{}},"type":"n8n-nodes-base.googleSheets","typeVersion":4.7,"position":[32,0],"id":"ce81b90d-72c4-4d6b-9af0-181cf4b391