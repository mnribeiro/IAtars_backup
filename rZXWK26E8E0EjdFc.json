{"updatedAt":"2025-11-16T17:53:56.127Z","createdAt":"2025-11-12T22:57:35.284Z","id":"rZXWK26E8E0EjdFc","name":"Disparo email","active":false,"isArchived":false,"nodes":[{"parameters":{},"type":"n8n-nodes-base.manualTrigger","typeVersion":1,"position":[-176,0],"id":"1f11f11e-1563-42d3-b4dc-b9fd041940e0","name":"When clicking ‘Execute workflow’"},{"parameters":{"assignments":{"assignments":[{"id":"0c004c63-50af-461e-8458-f89622a031e7","name":"Nome","value":"={{ $json.NOME }}","type":"string"},{"id":"19d945f8-7c47-412a-badb-0c7e4cb01456","name":"telefone","value":"={{ $json.telefone }}","type":"string"},{"id":"6d268d25-d728-42ce-8a13-3e7719f36182","name":"email_destino","value":"={{ $json.EMAIL }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[464,0],"id":"e54b3df6-66ee-4b34-bac6-4fd52e4abfd1","name":"Edit Fields"},{"parameters":{"html":"<!DOCTYPE html>\n<html lang=\"pt-BR\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Chegou a BS TECH - Brasil Solos</title>\n    <style>\n        body {\n            margin: 0;\n            padding: 0;\n            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;\n            background-color: #f4f4f4;\n        }\n        .email-container {\n            max-width: 600px;\n            margin: 0 auto;\n            background-color: #ffffff;\n        }\n        .header-image {\n            width: 100%;\n            display: block;\n        }\n        .content {\n            padding: 40px 30px;\n            color: #333333;\n            line-height: 1.8;\n        }\n        .content h1 {\n            color: #1a1a1a;\n            font-size: 24px;\n            margin-bottom: 20px;\n            font-weight: 600;\n        }\n        .content p {\n            font-size: 16px;\n            margin-bottom: 20px;\n            color: #555555;\n        }\n        .highlight {\n            color: #0066cc;\n            font-weight: 600;\n        }\n        .produtos {\n            background-color: #f8f9fa;\n            padding: 25px;\n            border-radius: 8px;\n            margin: 30px 0;\n        }\n        .produtos h2 {\n            font-size: 18px;\n            color: #1a1a1a;\n            margin-bottom: 15px;\n        }\n        .produtos ul {\n            list-style: none;\n            padding: 0;\n            margin: 0;\n        }\n        .produtos li {\n            margin-bottom: 15px;\n            padding-left: 25px;\n            position: relative;\n            font-size: 15px;\n            color: #555555;\n        }\n        .produtos li:before {\n            content: \"•\";\n            color: #0066cc;\n            font-size: 24px;\n            position: absolute;\n            left: 0;\n            top: -5px;\n        }\n        .produtos strong {\n            color: #1a1a1a;\n            font-weight: 600;\n        }\n        .cta-button {\n            display: inline-block;\n            padding: 16px 40px;\n            background-color: #0066cc;\n            color: #ffffff !important;\n            text-decoration: none;\n            border-radius: 6px;\n            font-size: 16px;\n            font-weight: 600;\n            margin: 30px 0;\n            transition: background-color 0.3s;\n        }\n        .cta-button:hover {\n            background-color: #0052a3;\n        }\n        .cta-center {\n            text-align: center;\n        }\n        .footer {\n            background-color: #f8f9fa;\n            color: #333333;\n            padding: 30px;\n            text-align: center;\n            font-size: 14px;\n        }\n        .footer p {\n            margin: 5px 0;\n            color: #555555;\n        }\n        .tagline {\n            font-style: italic;\n            color: #0066cc;\n            font-size: 15px;\n            margin-top: 10px;\n        }\n        @media only screen and (max-width: 600px) {\n            .content {\n                padding: 30px 20px;\n            }\n            .content h1 {\n                font-size: 20px;\n            }\n            .content p {\n                font-size: 15px;\n            }\n            .cta-button {\n                padding: 14px 30px;\n                font-size: 15px;\n            }\n        }\n    </style>\n</head>\n<body>\n    <div class=\"email-container\">\n        <!-- Imagem de topo -->\n        <img src=\"https://iili.io/KyHa6b9.png\" alt=\"Chegou a BS TECH - O novo braço de tecnologia da Brasil Solos\" class=\"header-image\">\n        \n        <!-- Conteúdo principal -->\n        <div class=\"content\">\n            <p>\n                Apresentamos a <span class=\"highlight\">BS TECH</span>, o nosso novo braço de tecnologia, criado para levar \n                <strong>inovação e inteligência</strong> aos laboratórios e profissionais de engenharia civil.\n            </p>\n            \n            <p>\n                A <span class=\"highlight\">BS TECH</span> nasceu dentro da prática de quem vive o controle tecnológico todos os dias.\n            </p>\n            \n            <p>\n                Desenvolvemos soluções que unem <strong>engenharia e tecnologia</strong>, transformando \n                dados em conhecimento e processos em resultados.\n            </p>\n            \n            <!-- Produtos -->\n            <div class=\"produtos\">\n                <h2>Entre as inovações já lançadas estão:</h2>\n                <ul>\n                    <li>\n                        <strong>Lab Code: Software de relatórios inteligentes</strong> — digitaliza e organiza todos \n                        os laudos de ensaio.\n                    </li>\n                    <li>\n                        <strong>IA para laboratoristas e engenheiros</strong> — uma sala de aula interativa que \n                        ensina, responde e otimiza a rotina técnica.\n                    </li>\n                </ul>\n            </div>\n            \n            <p>\n                Nosso propósito é simples: <strong>tornar o trabalho técnico mais preciso, ágil e conectado.</strong>\n            </p>\n            \n            <p>\n                Descubra como a tecnologia da <span class=\"highlight\">BS TECH</span> está transformando o setor de engenharia.\n            </p>\n            \n            <!-- CTA -->\n            <div class=\"cta-center\">\n                <a href=\"https://wa.me/5531988633298?text=Olá%2C%20quero%20saber%20mais%20sobre%20a%20BS%20TECH\" class=\"cta-button\">👉 Conheça a BS TECH</a>\n            </div>\n        </div>\n        \n        <!-- Rodapé -->\n        <div class=\"footer\">\n            <p><strong>BS TECH</strong></p>\n            <p>Uma unidade de tecnologia da Brasil Solos</p>\n            <p class=\"tagline\">Inovação que constrói o amanhã.</p>\n            <p style=\"font-size: 11px; color: #999; margin-top: 20px;\">\n                Não deseja mais receber nossos emails? \n                <a href=\"mailto:brasilsolos.tech@gmail.com\n?subject=Descadastrar&body=Solicito%20remoção%20da%20lista%20de%20emails\" style=\"color: #0066cc; text-decoration: none;\">\n                    Clique aqui\n                </a>\n            </p>\n        </div>\n    </div>\n</body>\n</html>"},"type":"n8n-nodes-base.html","typeVersion":1.2,"position":[688,0],"id":"5b9d7fe5-ba54-4dfe-a709-425694520dc2","name":"HTML"},{"parameters":{"sendTo":"={{ $('Edit Fields').item.json.email_destino }}","subject":"Chegou a BS TECH: o novo braço de tecnologia da Brasil Solos","message":"={{ $json.html }}","options":{}},"type":"n8n-nodes-base.gmail","typeVersion":2.1,"position":[1120,16],"id":"0479ad08-1465-4278-acc3-b690927b322c","name":"Send a message","webhookId":"841cf6c9-831d-4798-a23e-d29a81b8dc83","credentials":{"gmailOAuth2":{"id":"rJOvSJUAFmiVisS7","name":"Gmail Bstech"}}},{"parameters":{"options":{}},"type":"n8n-nodes-base.splitInBatches","typeVersion":3,"position":[896,0],"id":"88eb26ba-72