a8-c6d2-4b4d-9bd0-8eaefc961815","name":"Think1"},{"parameters":{"sessionIdType":"customKey","sessionKey":"={{ $('When chat message received').item.json.sessionId }}","contextWindowLength":0},"type":"@n8n/n8n-nodes-langchain.memoryRedisChat","typeVersion":1.5,"position":[-1440,128],"id":"334c4b45-b2c9-4be4-866a-385c97e3180e","name":"Redis Chat Memory"},{"parameters":{"modelName":"models/gemini-2.5-pro-preview-06-05","options":{}},"type":"@n8n/n8n-nodes-langchain.lmChatGoogleGemini","typeVersion":1,"position":[-2448,96],"id":"0739f200-4ee9-4d71-8eaa-17a76f665688","name":"Google Gemini Chat Model1"},{"parameters":{},"type":"@n8n/n8n-nodes-langchain.textSplitterCharacterTextSplitter","typeVersion":1,"position":[-2560,976],"id":"aa2b053a-39f1-491c-a8e6-6208643f3e2e","name":"Character Text Splitter1"},{"parameters":{"operation":"get","documentURL":"1N7ah5TWY7vBZW8lJ3nKMtt9ZVmFztXJGfNz7WyipCh4"},"type":"n8n-nodes-base.googleDocsTool","typeVersion":2,"position":[-2608,96],"id":"727441a1-48c6-4a55-aed9-dcb035e703ba","name":"base_conhecimento"},{"parameters":{"model":{"__rl":true,"value":"gpt-5","mode":"list","cachedResultName":"gpt-5"},"options":{"temperature":1}},"type":"@n8n/n8n-nodes-langchain.lmChatOpenAi","typeVersion":1.2,"position":[-1520,816],"id":"dc63f3b6-ae64-4998-a999-4997ab500811","name":"OpenAI Chat Model1"},{"parameters":{"text":"={{ /*n8n-auto-generated-fromAI-override*/ $fromAI('Prompt__User_Message_', ``, 'string') }}","needsFallback":true,"options":{}},"type":"@n8n/n8n-nodes-langchain.agentTool","typeVersion":2.2,"position":[-1424,528],"id":"e0eaad48-6cc0-4c43-aecb-05cf4a7d2c93","name":"AI Agent Tool1"},{"parameters":{"contextWindowLength":0},"type":"@n8n/n8n-nodes-langchain.memoryRedisChat","typeVersion":1.5,"position":[-1280,816],"id":"b0fa89fe-6b66-494e-b22b-4d3e5ead66d6","name":"Redis Chat Memory1"},{"parameters":{"text":"={{ /*n8n-auto-generated-fromAI-override*/ $fromAI('Prompt__User_Message_', ``, 'string') }}","hasOutputParser":true,"options":{}},"type":"@n8n/n8n-nodes-langchain.agentTool","typeVersion":2.2,"position":[-1104,528],"id":"4a17bd06-1947-4490-8d26-c1f7753cd632","name":"AI Agent Tool2"},{"parameters":{"toolDescription":"=# AGENTE: BUSCA_PRODUTO_AGENT\n\n## CONTEXTO E IDENTIDADE\nVocê é o `Busca_Produto_Agent`, o especialista em pesquisa de produtos e serviços para a Brasil Solos. Sua única responsabilidade é processar a solicitação do Orquestrador, buscar informações precisas em sua base de conhecimento e retornar um JSON estruturado com todos os dados relevantes. Sua interação é exclusiva com o Orquestrador.\n\n## FERRAMENTAS DISPONÍVEIS\n- **`Busca_codigo(termo_de_busca: string)`**: Recebe um termo e retorna um JSON com o nome, código, preço, e o contexto relacionado ao produto.\n- **`Busca_contexto(termo_de_busca: string)`**: Recebe um termo e retorna as perguntas de clarificação (`clarification_questions`) associadas àquele item ou contexto.\n\n## INSTRUÇÕES E PROCESSO\nSiga este processo rigoroso para cada requisição de busca do Orquestrador:\n\n### PASSO 1: Busca Detalhada\n-   Receba a solicitação do Orquestrador (ex: \"kit cbr\").\n-   Extraia o termo de busca mais relevante.\n-   Chame a ferramenta **`Busca_codigo`** com o termo.\n-   Simultaneamente, chame a ferramenta **`Busca_contexto`** com o mesmo termo para obter as perguntas de clarificação.\n\n### PASSO 2: Verificação e Consolidação\n-   Analise os retornos de ambas as ferramentas.\n-   **SE `Busca_codigo` retornar um produto e `Busca_contexto` retornar perguntas**:\n    1.  Consolide as informações do produto (nome, código, preço) com as perguntas de clarificação.\n    2.  Verifique se o resultado corresponde semanticamente à solicitação.\n    3.  Se a correspondência for alta, prepare o JSON de retorno.\n-   **SE `Busca_codigo` falhar ou `Busca_contexto` não encontrar perguntas relevantes**:\n    1.  Indique a falha e retorne um JSON apropriado.\n\n### PASSO 3: Formato de Saída para o Orquestrador\nO output deste agente deve ser um objeto JSON bem estruturado, contendo todas as informações para que o Orquestrador possa tomar a próxima decisão.\n\n- **Exemplo de sucesso**:\n  ```json\n  {\n    \"status\": \"sucesso\",\n    \"detalhes_da_busca\": {\n      \"nome\": \"Prensa CBR / ISC Manual\",\n      \"codigo\": \"BSC-00123\",\n      \"preco\": \"R$ 5.000,00\",\n      \"perguntas_clarificacao\": \"Certo. Pra esse kit CBR, a prensa é a manual ou a elétrica?\"\n    }\n  }","text":"={{ $fromAI('Prompt__User_Message_', ``, 'string') }}","hasOutputParser":true,"options":{}},"type":"@n8n/n8n-nodes-langchain.agentTool","typeVersion":2.2,"position":[-1776,544],"id":"305de3d9-5846-44d0-bd31-d2c899b0ac94","name":"AI Agent Tool"},{"parameters":{"url":"http://brasilsolos.nomus.com.br/brasilsolos/rest/clientes","sendQuery":true,"queryParameters":{"parameters":[{"name":"query","value":"municipio=\"São Paulo\""}]},"sendHeaders":true,"headerParameters":{"parameters":[{"name":"Authorization","value":"Basic aW50ZWdyYWRvcmVycDpTcjVJeklFWnZvc2FaQ0Q="}]},"sendBody":true,"bodyParameters":{"parameters":[{}]},"options":{"redirect":{"redirect":{}}}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[0,0],"id":"85bff5ca-4238-462a-b7db-39cc5f94f32f","name":"HTTP Request"},{"parameters":{"url":"http://brasilsolos.nomus.com.br/brasilsolos/rest/clientes","sendQuery":true,"queryParameters":{"parameters":[{"name":"numeroPagina","value":"1"}]},"sendHeaders":true,"headerParameters":{"parameters":[{"name":"Authorization","value":"Basic aW50ZWdyYWRvcmVycDpTcjVJeklFWnZvc2FaQ0Q="}]},"sendBody":true,"bodyParameters":{"parameters":[{}]},"options":{"redirect":{"redirect":{}}}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[304,16],"id":"1e4eee92-4108-4964-8cd7-29e02b9a5d1b","name":"HTTP Request1"},{"parameters":{"url":"http://brasilsolos.nomus.com.br/brasilsolos/rest/clientes","sendQuery":true,"queryParameters":{"parameters":[{"name":"pagina","value":"2"}]},"sendHeaders":true,"headerParameters":{"pa